# Template only (not auto-loaded at runtime).
# Copy values to:
# - .env.development.local (local development)
# - .env.test.local (local test overrides)
# - .env.production.local (optional local production file)
# Note: .env.local is no longer supported.
# For sensitive integration keys (R2/Bakong), ask tech lead; do not commit real values.

# Database Configuration
DATABASE_URL=postgres://postgres:yourpassword@localhost:5432/dbname

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production

# Server Configuration
PORT=3000
NODE_ENV=development
V0_OUTBOX_DISPATCHER_ENABLED=true
V0_OUTBOX_DISPATCHER_INTERVAL_MS=1000
V0_OUTBOX_DISPATCHER_BATCH_SIZE=100


# KHQR config
V0_KHQR_PROVIDER=Bakong
V0_KHQR_WEBHOOK_SECRET= your-secret-for-development
V0_KHQR_WEBHOOK_SECRET_HEADER=x-khqr-webhook-secret
V0_KHQR_PROVIDER_BASE_URL=https://api-bakong.nbc.gov.kh/v1
V0_KHQR_PROVIDER_API_KEY=
V0_KHQR_PROVIDER_API_KEY_HEADER=authorization
V0_KHQR_DEBUG_VERIFY=false

V0_KHQR_PROVIDER_TIMEOUT_MS=5000
V0_KHQR_ATTEMPT_TTL_SECONDS=300
V0_KHQR_RECONCILIATION_ENABLED=true
V0_KHQR_RECONCILIATION_INTERVAL_MS=30000
V0_KHQR_RECONCILIATION_BATCH_SIZE=50
V0_KHQR_RECONCILIATION_RECHECK_WINDOW_MINUTES=2

OFFLINE_SYNC_OPERATION_LEASE_MS=120000
V0_MEDIA_CLEANUP_ENABLED=true
V0_MEDIA_CLEANUP_INTERVAL_MS=60000
V0_MEDIA_CLEANUP_BATCH_SIZE=100
V0_MEDIA_CLEANUP_PENDING_AGE_MINUTES=1440

# Object Storage Config
R2_ACCOUNT_ID=
R2_BUCKET_NAME=modula-dev
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_URL=
API_BASE_URL=


# Local Auth Fallback (used when V0_AUTH_PROVIDER=local)
AUTH_FIXED_OTP=123456
V0_AUTH_OTP_EXPIRY_MINUTES=10
V0_AUTH_OTP_MAX_ATTEMPTS=5
V0_AUTH_OTP_RESEND_COOLDOWN_SECONDS=60
V0_AUTH_OTP_MAX_PER_HOUR=6
V0_AUTH_ACCESS_TOKEN_TTL=12h
V0_AUTH_REFRESH_TOKEN_TTL=7d
V0_FAIRUSE_TENANT_COUNT_PER_ACCOUNT_HARD=20
V0_FAIRUSE_TENANT_PROVISION_RATE_LIMIT=10
V0_FAIRUSE_TENANT_PROVISION_WINDOW_SECONDS=3600
V0_FAIRUSE_BRANCH_COUNT_PER_TENANT_HARD=100
V0_FAIRUSE_BRANCH_ACTIVATION_RATE_LIMIT=30
V0_FAIRUSE_BRANCH_ACTIVATION_WINDOW_SECONDS=3600
V0_FIRST_BRANCH_PAYMENT_STUB_TOKEN=PAID
V0_FIRST_BRANCH_ACTIVATION_FEE_USD=5.00
V0_ADDITIONAL_BRANCH_ACTIVATION_FEE_USD=5.00
